<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.devtool.controller.PasswordPageController"
      styleClass="page-container"
      spacing="0"
      style="-fx-padding: 16;">

    <!-- ── 页面标题 ── -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 16 0;">
        <Label text="&#128272;" style="-fx-font-size: 20px;"/>
        <Label text="随机密码生成器" styleClass="title-label"/>
    </HBox>

    <!-- ── 主体内容（左右分栏） ── -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- ══ 左侧：配置区 ══ -->
        <VBox spacing="12" prefWidth="280" minWidth="260"
              style="-fx-background-color:#313335; -fx-border-color:#444; -fx-border-radius:5; -fx-background-radius:5; -fx-padding:16;">

            <!-- 密码长度 -->
            <VBox spacing="6">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="密码长度" style="-fx-text-fill:#ccc; -fx-font-size:13px;"/>
                    <Label fx:id="lengthValueLabel" text="16"
                           style="-fx-text-fill:#4a9eff; -fx-font-size:14px; -fx-font-weight:bold;"/>
                </HBox>
                <Slider fx:id="lengthSlider" min="4" max="64" value="16" blockIncrement="1"
                        showTickLabels="true" showTickMarks="true" majorTickUnit="12" minorTickCount="3"
                        style="-fx-accent:#4a6fa5;"/>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="自定义长度:" style="-fx-text-fill:#888; -fx-font-size:12px;"/>
                    <TextField fx:id="customLengthField" promptText="4-128" prefWidth="70"
                               style="-fx-font-size:12px;"/>
                </HBox>
            </VBox>

            <Separator style="-fx-opacity:0.4;"/>

            <!-- 字符集选项 -->
            <VBox spacing="8">
                <Label text="字符集" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-font-weight:bold;"/>
                <CheckBox fx:id="chkUppercase" text="大写字母 (A-Z)" selected="true"
                          style="-fx-text-fill:#ccc; -fx-font-size:13px;"/>
                <CheckBox fx:id="chkLowercase" text="小写字母 (a-z)" selected="true"
                          style="-fx-text-fill:#ccc; -fx-font-size:13px;"/>
                <CheckBox fx:id="chkDigits"    text="数字 (0-9)"    selected="true"
                          style="-fx-text-fill:#ccc; -fx-font-size:13px;"/>
                <CheckBox fx:id="chkSymbols"   text="特殊符号 (!@#...)" selected="true"
                          style="-fx-text-fill:#ccc; -fx-font-size:13px;"/>
            </VBox>

            <Separator style="-fx-opacity:0.4;"/>

            <!-- 额外规则 -->
            <VBox spacing="8">
                <Label text="额外规则" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-font-weight:bold;"/>
                <CheckBox fx:id="chkNoAmbiguous" text="排除易混淆字符 (0/O, 1/l/I)" selected="false"
                          style="-fx-text-fill:#ccc; -fx-font-size:12px;"/>
                <CheckBox fx:id="chkEachType"    text="每种类型至少包含一个"     selected="true"
                          style="-fx-text-fill:#ccc; -fx-font-size:12px;"/>
            </VBox>

            <Separator style="-fx-opacity:0.4;"/>

            <!-- 自定义符号 -->
            <VBox spacing="6">
                <Label text="自定义特殊符号（留空则使用默认）"
                       style="-fx-text-fill:#888; -fx-font-size:11px;"/>
                <TextField fx:id="customSymbolsField" promptText="例如：!@#$%"
                           style="-fx-font-size:12px;"/>
            </VBox>

            <Separator style="-fx-opacity:0.4;"/>

            <!-- 生成数量 -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="生成数量:" style="-fx-text-fill:#ccc; -fx-font-size:13px;"/>
                <Spinner fx:id="countSpinner" min="1" max="50" initialValue="1" prefWidth="80"
                         style="-fx-font-size:13px;"/>
            </HBox>

            <!-- 生成按钮 -->
            <Button text="🎲  生成密码" onAction="#onGenerate"
                    maxWidth="Infinity" styleClass="button-primary"
                    style="-fx-font-size:14px; -fx-font-weight:bold; -fx-padding:9 0; -fx-border-radius:4; -fx-background-radius:4; -fx-cursor:hand;"/>

        </VBox>

        <!-- ══ 右侧：结果区 ══ -->
        <VBox spacing="8" HBox.hgrow="ALWAYS">

            <!-- 强度指示器 -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color:#313335; -fx-border-color:#444; -fx-border-radius:5; -fx-background-radius:5; -fx-padding:10 14;">
                <Label text="密码强度:" style="-fx-text-fill:#aaa; -fx-font-size:13px;"/>
                <Label fx:id="strengthLabel" text="—"
                       style="-fx-font-size:13px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="charSetLabel" text=""
                       style="-fx-text-fill:#666; -fx-font-size:11px;"/>
            </HBox>

            <!-- 密码结果列表 -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color:#313335; -fx-border-color:#444; -fx-border-radius:5; -fx-background-radius:5; -fx-padding:10;">
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:0 0 8 0;">
                    <Label text="生成结果" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-font-weight:bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="全部复制" styleClass="json-action-btn" onAction="#onCopyAll"/>
                    <Button text="清空"     styleClass="json-action-btn" onAction="#onClear"/>
                </HBox>
                <ListView fx:id="resultList" VBox.vgrow="ALWAYS"
                          style="-fx-background-color:#1e1e1e; -fx-control-inner-background:#1e1e1e; -fx-border-color:#444; -fx-border-radius:3; -fx-background-radius:3; -fx-font-family:'Consolas','Courier New',monospace; -fx-font-size:14px;"/>
            </VBox>

            <!-- 底部操作栏 -->
            <HBox spacing="8" alignment="CENTER_LEFT"
                  style="-fx-background-color:#313335; -fx-border-color:#444; -fx-border-radius:5; -fx-background-radius:5; -fx-padding:10 14;">
                <Label fx:id="statusLabel" text="点击「生成密码」开始"
                       style="-fx-text-fill:#666; -fx-font-size:12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="复制选中" styleClass="json-action-btn" onAction="#onCopySelected"/>
                <Button text="重新生成" styleClass="button-primary" onAction="#onGenerate"
                        style="-fx-font-size:12px; -fx-padding:4 14; -fx-border-radius:3; -fx-background-radius:3; -fx-cursor:hand;"/>
            </HBox>

        </VBox>
    </HBox>

</VBox>

