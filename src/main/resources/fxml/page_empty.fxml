<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.devtool.controller.EmptyPageController"
      styleClass="page-container"
      spacing="0"
      style="-fx-padding: 30 40;">

    <!-- ── 顶部：应用标题 ── -->
    <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 0 0 24 0;">
        <Label text="&#9874;" style="-fx-font-size: 42px; -fx-text-fill:#61afef;"/>
        <VBox spacing="4">
            <Label fx:id="titleLabel" text="DevToolBox 开发者工具箱" styleClass="title-label"
                   style="-fx-font-size:26px;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="versionLabel" text="v1.0.10" styleClass="version-label"
                       style="-fx-font-size:13px; -fx-background-color:#2a3a2a; -fx-text-fill:#98c379;
                              -fx-padding:2 10; -fx-border-radius:10; -fx-background-radius:10;"/>
                <Label text="Java 17 + JavaFX 17  ·  纯本地运算，部分功能需联网" 
                       style="-fx-text-fill:#555; -fx-font-size:12px;"/>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- 统计 -->
        <VBox alignment="CENTER_RIGHT" spacing="4">
            <Label fx:id="statsToolLabel" text="13 个工具"
                   style="-fx-text-fill:#4a6fa5; -fx-font-size:18px; -fx-font-weight:bold;"/>
            <Label text="已上线" style="-fx-text-fill:#666; -fx-font-size:11px;"/>
        </VBox>
    </HBox>

    <Separator style="-fx-opacity:0.3;"/>

    <!-- ── 中部：工具网格 ── -->
    <Label text="&#128640; 所有工具" style="-fx-text-fill:#d19a66; -fx-font-size:12px; -fx-font-weight:bold; -fx-padding:16 0 12 0;"/>

    <!-- 第一行 -->
    <HBox spacing="12" style="-fx-padding:0 0 12 0;">
        <!-- JSON 工具箱 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128203;" style="-fx-font-size:20px; -fx-text-fill:#e5c07b;"/>
                <Label text="JSON 工具箱" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="格式化 · 压缩 · 转义 · JSON对比差异 · 生成Java/Python/Go实体类 · 实体类→JSON"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <!-- 随机密码 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128272;" style="-fx-font-size:20px; -fx-text-fill:#98c379;"/>
                <Label text="随机密码生成" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="可配置长度/字符集/规则 · 强度评估 · 批量生成 · 排除易混淆字符"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <!-- 二维码 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128247;" style="-fx-font-size:20px; -fx-text-fill:#61afef;"/>
                <Label text="二维码生成" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="文本/网址/邮箱 · 可调尺寸 · 保存PNG · 复制到剪贴板"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
    </HBox>

    <!-- 第二行 -->
    <HBox spacing="12" style="-fx-padding:0 0 12 0;">
        <!-- Cron -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#9200;" style="-fx-font-size:20px; -fx-text-fill:#c678dd;"/>
                <Label text="Cron 表达式" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="可视化配置 · 实时解析 · 下次10次触发时间 · 14个常用模板"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <!-- 加密解密 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128272;" style="-fx-font-size:20px; -fx-text-fill:#be5046;"/>
                <Label text="加密解密" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="MD5/SHA/HMAC实时计算 · AES-CBC/ECB · Base64 · URL编解码"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <!-- 时间戳 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#9200;" style="-fx-font-size:20px; -fx-text-fill:#56b6c2;"/>
                <Label text="时间戳工具" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="实时时钟 · 时间戳↔日期转换 · 14时区显示 · 日期差计算"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
    </HBox>

    <!-- 第三行 -->
    <HBox spacing="12" style="-fx-padding:0 0 12 0;">
        <!-- SQL -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128452;" style="-fx-font-size:20px; -fx-text-fill:#98c379;"/>
                <Label text="SQL 工具箱" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="格式化 · 语法检测 · 关键字大小写 · 参数填充 · INSERT模板 · 提取元信息"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <!-- 文本处理 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128196;" style="-fx-font-size:20px; -fx-text-fill:#e06c75;"/>
                <Label text="文本批量处理" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="批量替换(正则) · 行操作 · 大小写/snake/camel · 编码转换 · 实时统计"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <!-- 开发日报 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128202;" style="-fx-font-size:20px; -fx-text-fill:#61afef;"/>
                <Label text="开发日报生成" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="读取本地Git日志 · 日期范围查询 · 分天导航 · 多格式输出 · 智能摘要分类"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
    </HBox>

    <!-- 第四行 -->
    <HBox spacing="12" style="-fx-padding:0 0 12 0;">
        <!-- 调试工具（摸鱼神器） -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128640;" style="-fx-font-size:20px; -fx-text-fill:#c678dd;"/>
                <Label text="调试工具" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Label text="（内置浏览器）" style="-fx-text-fill:#4a6fa5; -fx-font-size:11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="内置浏览器 · 深色主题注入 · Ctrl+W 一键 Boss 键切换掩护代码界面"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#129518;" style="-fx-font-size:20px; -fx-text-fill:#d19a66;"/>
                <Label text="计算器" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="完整计算过程历史 · 结果/表达式/整行一键复制 · 支持括号/幂/√/键盘快捷键"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- 第五行 -->
    <HBox spacing="12" style="-fx-padding:0 0 12 0;">
        <!-- AI 助手 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="AI" style="-fx-background-color:#56b6c2; -fx-text-fill:#1e1e1e; -fx-font-size:12px; -fx-font-weight:bold; -fx-padding:2 6; -fx-background-radius:4;"/>
                <Label text="AI 助手" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Label text="（需配置 API）" style="-fx-text-fill:#56b6c2; -fx-font-size:11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="OpenAI-compatible 对话 · 系统提示词 · 上下文会话 · 回复复制 · 本地保存连接配置"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <!-- 翻译助手 -->
        <VBox styleClass="home-card" HBox.hgrow="ALWAYS" spacing="6">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#128218;" style="-fx-font-size:20px; -fx-text-fill:#4a6fa5;"/>
                <Label text="翻译助手" style="-fx-text-fill:#e0e0e0; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Label text="（多语言）" style="-fx-text-fill:#4a6fa5; -fx-font-size:11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="✅" style="-fx-font-size:11px;"/>
            </HBox>
            <Label text="12种语言互译 · 英文单词释义/音标/变形 · 生词本本地存储 · 支持自动检测语言"
                   style="-fx-text-fill:#888; -fx-font-size:11px;" wrapText="true"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- ── 底部：使用提示 + 版权 ── -->
    <HBox alignment="CENTER_LEFT" spacing="20"
          style="-fx-background-color:#252525; -fx-border-color:#3a3a3a; -fx-border-radius:5;
                 -fx-background-radius:5; -fx-padding:10 16;">
        <Label text="&#128161;" style="-fx-font-size:14px; -fx-text-fill:#e5c07b;"/>
        <Label text="点击左侧导航栏选择工具开始使用  ·  大部分功能本地运行，AI/翻译等功能会访问已配置的网络服务"
               style="-fx-text-fill:#666; -fx-font-size:12px;" HBox.hgrow="ALWAYS"/>
        <Label text="联系作者：jactil777@gmail.com"
               style="-fx-text-fill:#4a6fa5; -fx-font-size:11px;"/>
        <Label fx:id="copyrightLabel" text="DevToolBox  ©  2026"
               style="-fx-text-fill:#444; -fx-font-size:11px;"/>
    </HBox>

</VBox>
